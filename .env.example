# YouTube Data API v3 key
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Sheets ID for YouTube tracker
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets ID for TikTok/Instagram tracker
SOCIAL_SHEET_ID=your_social_sheet_id_here

# Path to service account JSON file (for local development)
# For GitHub Actions, store the entire JSON content in GOOGLE_SERVICE_ACCOUNT_JSON secret
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
